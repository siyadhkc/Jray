{
  "name": "@siyadkc/jray",
  "version": "0.2.4",
  "description": "A Bun-based CLI to flatten, filter, and reconstruct JSON from the command line.",
  "author": "siyadhkc",
  "license": "MIT",
  "bin": {
    "jray": "./dist/jray.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "test": "bun test",
    "build": "bun build src/bin.ts --target bun --outfile dist/jray.js",
    "build:native": "bun build src/bin.ts --compile --outfile dist/jray",
    "prepack": "bun run build"
  },
  "keywords": [
    "json",
    "cli",
    "flatten",
    "gron",
    "jq",
    "query",
    "typescript",
    "bun",
    "command-line",
    "developer-tools"
  ],
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/siyadhkc/Jray.git"
  },
  "homepage": "https://siyadhkc.github.io/Jray",
  "bugs": {
    "url": "https://github.com/siyadhkc/Jray/issues"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/bun": "latest"
  }
}
