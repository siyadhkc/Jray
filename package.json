{
  "name": "@siyadkc/jray",
  "version": "0.2.2",
  "description": "Flatten, filter, and reconstruct JSON from the command line. A modern alternative to gron.",
  "author": "siyadhkc",
  "license": "MIT",
  "bin": {
    "jray": "./src/bin.ts"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "test": "bun test",
    "build": "bun build src/bin.ts --target bun --outfile dist/jray.js",
    "build:native": "bun build src/cli.ts --compile --outfile dist/jray"
  },
  "keywords": [
    "json", "cli", "flatten", "gron", "jq",
    "query", "typescript", "bun", "command-line", "developer-tools"
  ],
  "files": [
    "src/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/siyadhkc/Jray.git"
  },
  "homepage": "https://siyadhkc.github.io/Jray",
  "bugs": {
    "url": "https://github.com/siyadhkc/Jray/issues"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/bun": "latest"
  }
}
